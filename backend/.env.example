SHARPE_TRACKER_ADDRESS=0x85a6394b36B075825Af18030EB3c57Dfac157A0F

# Adapters
WDK_XAUT_ADAPTER_ADDRESS=0x52AfFd555f769d50907837DaFC8575C703150421
WDK_SECONDARY_ADAPTER_ADDRESS=0xd2a701f702Da660A4e8D7613076cfd6065695349
WDK_LP_ADAPTER_ADDRESS=0x71e3010Df995C1D611AbD3C5BdB198c677D6D65c
WDK_LENDING_ADAPTER_ADDRESS=0xEEACEFecfe9834c7DC658fdEDA367722BacF7813

# Extended Contracts
WDK_AUCTION_ADDRESS=0x3fe160021429d3dAa606791f3cf6323A57A5126a
WDK_MULTI_ORACLE_ADDRESS=0xc2810A869a35C1eC8A51b39f6bfCF951F186Ec5A
