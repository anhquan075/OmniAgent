# OmniAgent FastAPI BNB mainnet runtime
PORT=8000
OMNIAGENT_LOG_JSON=true
OMNIAGENT_LOG_LEVEL=INFO
OMNIAGENT_LOG_STREAM=stdout
BNB_CHAIN_ID=56
BNB_RPC_URL=https://bsc-dataseed.bnbchain.org
BNB_EXPLORER_URL=https://bscscan.com
BNB_COMPETITION_CONTRACT_ADDRESS=0x212c61b9b72c95d95bf29cf032f5e5635629aed5
BNB_PANCAKE_SWAP_ROUTER_ADDRESS=0x10ED43C718714eb63d5aA57B78B54704E256024E
BNB_BUNDLED_REGISTRATION_PROOF_ENABLED=false
BNB_TOKEN_ALLOWLIST=BNB,USDT,USDC,CAKE,TWT

# Keep live execution false until market signal proof, wallet signer, SDK identity,
# registration, capital, and pause recovery are verified. The backend loop can run
# automatically in guarded mode and the frontend remains read-only.
BNB_TRADING_ENABLED=false
ALLOW_AGENT_RUN=false
BNB_AUTONOMOUS_LOOP_ENABLED=true
BNB_AUTONOMOUS_LOOP_EXECUTE=false
BNB_AUTONOMOUS_LOOP_INTERVAL_SEC=300
BNB_AUTONOMOUS_LOOP_INITIAL_DELAY_SEC=5
BNB_AUTONOMOUS_LOOP_SYMBOL=CAKE
BNB_AUTONOMOUS_LOOP_SIDE=buy
BNB_AUTONOMOUS_LOOP_AMOUNT_USD=25
BNB_AUTONOMOUS_LOOP_SLIPPAGE_BPS=50
BNB_STRATEGY_ADVISOR_ENABLED=true
BNB_STRATEGY_REQUIRE_LLM_FOR_LIVE=false
BNB_STRATEGY_MIN_CONFIDENCE=0.62
BNB_STRATEGY_MAX_POSITION_PCT=0.35
BNB_MAX_TRADE_USD=25
BNB_MAX_SLIPPAGE_BPS=100
BNB_MAX_DRAWDOWN_PCT=30
BNB_MAX_DAILY_TRADES=12

# Public agent wallet controlled by Trust Wallet Agent Kit.
TWAK_AGENT_WALLET=
ROBOT_FLEET_AGENT_WALLET=

# CoinMarketCap Agent Hub.
CMC_AGENT_HUB_BASE_URL=https://pro-api.coinmarketcap.com
CMC_MCP_URL=https://mcp.coinmarketcap.com/mcp
CMC_SKILL_HUB_MCP_URL=https://mcp.coinmarketcap.com/skill-hub/stream
CMC_SKILL_HUB_TOOL_TIMEOUT_SEC=300
CMC_AGENT_HUB_API_KEY=
CMC_SKILL_HUB_API_KEY=
CMC_MCP_API_KEY=
CMC_PRO_API_KEY=
COINMARKETCAP_API_KEY=
X_CMC_PRO_API_KEY=
CMC_AGENT_HUB_SIGNAL_TOOL=
CMC_AGENT_HUB_SIGNAL_ARGS={}

# Optional backend-only strategy advisor. Never expose this key in frontend envs.
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=deepseek/deepseek-v4-pro
OPENROUTER_FALLBACK_MODEL=deepseek/deepseek-v4-flash
OPENROUTER_SITE_URL=
OPENROUTER_APP_NAME=OmniAgent BNB Trading Agent

# Trust Wallet Agent Kit REST bridge.
TRUST_WALLET_AGENT_KIT_MODE=disabled
TRUST_WALLET_AGENT_KIT_CONFIG={"baseUrl":"http://localhost:8787"}
# Local dev may use ~/.twak/credentials.json; deployments should set TW_HMAC_SECRET.
TW_ACCESS_ID=
TW_HMAC_SECRET=



# BNB Agent SDK identity registration.
BNB_AGENT_SDK_ENABLED=false
BNB_AGENT_SDK_REGISTRATION_ENABLED=false
BNB_AGENT_SDK_NETWORK=bsc-mainnet
BNB_AGENT_PUBLIC_ENDPOINT=https://omniagent.example/.well-known/agent-card.json

# Competition registration stays explicit.
BNB_COMPETITION_REGISTRATION_ENABLED=false

# x402 proof remains not claimed until a verifier is configured.
ROBOT_FLEET_X402_ENABLED=false
X402_FACILITATOR_URL=
X402_NETWORK=eip155:56
X402_PAYMENT_VERIFIER_URL=

TRADE_LEDGER_PATH=backend/data/trade-ledger.jsonl
