WDK_XAUT_ORACLE_ADDRESS=0x1b44F3514812d835EB1BDB0acB33d3fA3351Ee43
# TWAP oracle deprecated - using Chainlink oracles instead
# WDK_TWAP_ORACLE_ADDRESS=

# ─── Integrations ────────────────────────────────────────────────────────────
AGENT_REPORT_URL=
AGENT_REPORT_BASE_URL=
GITHUB_WEBHOOK_SECRET=

# ─── OpenClaw Protocol ────────────────────────────────────────────────────────
OPENCLAW_GATEWAY_URL=https://gateway.openclaw.com/api
OPENCLAW_API_KEY=
MAX_OPENCLAW_EXPOSURE_PERCENT=20
MIN_OPENCLAW_APY=8.5

# ─── Velora DEX ──────────────────────────────────────────────────────────────
VELORA_ROUTER_ADDRESS=0x7a250d5630B4cF539739dF2C5dAcb4c659F2488D
VELORA_FACTORY_ADDRESS=0x5C69bEe701ef814a2B6a3EDD4B1652CB9cc5aA6f

# ─── ERC-4337 Smart Accounts (EntryPoint v0.7) ────────────────────────────────
# SimpleAccountFactory with session key support (deployed on Sepolia)
SIMPLE_ACCOUNT_FACTORY_ADDRESS=0x738428DD7930EBB2f61763a18C805782A1A6586b
# Legacy Pimlico addresses (for reference)
ERC4337_FACTORY_ADDRESS=
ERC4337_PAYMASTER_ADDRESS=0x777777777777AeC03fd955926DbF81597e66834C
ERC4337_ENTRYPOINT_ADDRESS=0x0000000071727De22E5E9d8BAf0edAc6f37da032
ERC4337_BUNDLER_URL=https://public.pimlico.io/v2/11155111/rpc
ERC4337_PAYMASTER_URL=https://public.pimlico.io/v2/11155111/rpc
ERC4337_SAFE_MODULES_VERSION=0.3.0
ERC4337_USDT_TOKEN=0xd077a400968890eacc75cdc901f0356c943e4fdb
ERC4337_TRANSFER_MAX_FEE=100000

# ─── External Network Addresses ───────────────────────────────────────────────
AAVE_V3_POOL_ARBITRUM=0x6Ae43d3271ff6888e7Fc43Fd7321a503ff738951
USDT_ARBITRUM=0xFd086bC7CD5C481DCC9C96ebFK90d351BfA8365

# ─── Mainnet Token Addresses ──────────────────────────────────────────────────
MAINNET_USDT=0xdAC17F958D2ee523a2206206994597C13D831ec7
MAINNET_XAUT=0x68749665FF8D2d112Fa859AA293F07A622782F38
MAINNET_WETH=0xC02aaA39b223FE8D0A0e5C4F27eAD9083C756Cc2

# ─── x402 Protocol (Semantic Facilitator) ──────────────────────────────────────
X402_FACILITATOR_URL=https://x402.semanticpay.io/
X402_NETWORK=eip155:9745
X402_USDT0_PLASMA=0xB8CE59FC3717ada4C02eaDF9682A9e934F625ebb
X402_USDT0_STABLE=0x779Ded0c9e1022225f8E0630b35a9b54bE713736

# ─── Deployment ───────────────────────────────────────────────────────────────
DEPLOYMENT_MODE=local
AGENT_CRON_SECRET=
JWT_SECRET=
ALLOW_AGENT_RUN=true

# ─── Robot Fleet ──────────────────────────────────────────────────────────────
ROBOT_FLEET_ENABLED=false
ROBOT_FLEET_SIZE=8
ROBOT_FLEET_TASK_INTERVAL_MIN=5000
ROBOT_FLEET_TASK_INTERVAL_MAX=15000
ROBOT_FLEET_EARNINGS_MIN=0.1
ROBOT_FLEET_EARNINGS_MAX=0.5
ROBOT_FLEET_AGENT_WALLET=
ROBOT_FLEET_USE_WDK_AGENTS=true
ROBOT_FLEET_X402_ENABLED=true
# Override robot fleet config (JSON array). If not set, uses default robots.
# ROBOT_FLEET_ROBOTS=[{"id":"ROBO-001","type":"Yield Sentry","icon":"[S]","capabilities":["swap","lend"],"x402Endpoints":["https://api.example.com/task"]},...]

# ─── Mock Contracts (Testnet) ─────────────────────────────────────────────────
MOCK_AAVE_POOL_ADDRESS=
MOCK_BRIDGE_ADDRESS=
MOCK_ATOKEN_ADDRESS=
MOCK_VUSDT_ADDRESS=

# ─── NAV Shield ──────────────────────────────────────────────────────────────
# Baseline storage path (Railway Volume: /app/cache, local: ./cache)
BASELINE_STORAGE_PATH=
# Maximum NAV drop % per trade (default: 10)
NAV_MAX_DROP_PCT=10

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=info
NODE_ENV=development
