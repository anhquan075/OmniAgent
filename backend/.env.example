# OmniWDK Agent - Backend Environment Variables
# Copy this file to .env.wdk (or .env) and fill in the values

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3001

# ─── OpenRouter (AI / LLM) ────────────────────────────────────────────────────
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL_GENERAL=google/gemini-2.5-flash-lite
OPENROUTER_MODEL_CRYPTO=x-ai/grok-4.1-fast

# ─── Blockchain RPCs ──────────────────────────────────────────────────────────
# BNB Chain RPC URL (default: Lama RPC)
BNB_RPC_URL=https://binance.llamarpc.com

# Solana RPC URL (default: mainnet-beta)
# For faster/more reliable RPC, consider services like: Helius, Magic Eden, Quicknode
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# TON RPC URL (default: toncenter.com)
# For production, consider: Getblock, QuickNode, or self-hosted
TON_RPC_URL=https://toncenter.com/api/v2/jsonRPC

# ─── WDK Wallet / Seed ────────────────────────────────────────────────────────
# REQUIRED: BIP-39 mnemonic or hex seed for the agent wallet
WDK_SECRET_SEED=

# ─── WDK Contract Addresses (required) ───────────────────────────────────────
WDK_VAULT_ADDRESS=
WDK_ENGINE_ADDRESS=
WDK_USDT_ADDRESS=
WDK_BREAKER_ADDRESS=
WDK_ZK_ORACLE_ADDRESS=

# ─── WDK Contract Addresses (optional) ───────────────────────────────────────
WDK_AUCTION_ADDRESS=
WDK_SYNDICATE_ADDRESS=
WDK_XAUT_ADDRESS=
WDK_RISK_POLICY_ADDRESS=
WDK_SHARPE_TRACKER_ADDRESS=
WDK_AAVE_ADAPTER_ADDRESS=
WDK_LZ_ADAPTER_ADDRESS=

# ─── Integrations (optional) ──────────────────────────────────────────────────
# Base URL for agent report endpoint (e.g., https://example.com or http://localhost:3001)
# If not set, defaults to http://localhost:{PORT}
AGENT_REPORT_BASE_URL=

# URL the agent will POST reports to (e.g. internal dashboard)
AGENT_REPORT_URL=

# Secret for validating GitHub webhook payloads
GITHUB_WEBHOOK_SECRET=

# ─── OpenClaw Protocol (optional) ─────────────────────────────────────────────
# Gateway URL for OpenClaw protocol access (fallback to WDK protocol modules)
OPENCLAW_GATEWAY_URL=https://gateway.openclaw.com/api
OPENCLAW_API_KEY=

# OpenClaw Risk Management Parameters
MAX_OPENCLAW_EXPOSURE_PERCENT=20
MIN_OPENCLAW_APY=8.5

# ─── Velora DEX Integration (optional) ────────────────────────────────────────
# Router address for Velora DEX on BNB Chain
VELORA_ROUTER_ADDRESS=0x7a250d5630B4cF539739dF2C5dAcb4c659F2488D

# Factory address for Velora DEX
VELORA_FACTORY_ADDRESS=0x5C69bEe701ef814a2B6a3EDD4B1652CB9cc5aA6f

# ─── ERC-4337 Smart Accounts ───────────────────────────────────────────────────────
# Factory address for ERC-4337 smart accounts
# Use SimpleAccountFactory: 0x9406Cc6185a346906296840746125a0E449c54A (mainnet)
ERC4337_FACTORY_ADDRESS=
ERC4337_ENTRYPOINT_ADDRESS=0x5FF137D4a0ADCA4B1FB0b8274Ea4dE461a706c12

# ─── Deployment ───────────────────────────────────────────────────────────────
# "local" = runs autonomous loop internally, "production" = expects external cron
DEPLOYMENT_MODE=local

# Secret for authenticating cron-triggered agent cycles (POST /api/agent/run-cycle)
AGENT_CRON_SECRET=

# ─── Mock Contracts for Testnet ─────────────────────────────────────────────────
# Deployed via: npx hardhat run scripts/DeployMockAaveAndBridge.ts --network bnbTestnet
MOCK_AAVE_POOL_ADDRESS=
MOCK_BRIDGE_ADDRESS=
MOCK_ATOKEN_ADDRESS=
