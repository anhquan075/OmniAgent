# ProofVault Agent - Backend Environment Variables
# Copy this file to .env.wdk (or .env) and fill in the values

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3001

# ─── OpenRouter (AI / LLM) ────────────────────────────────────────────────────
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL_GENERAL=google/gemini-2.0-flash-exp:free
OPENROUTER_MODEL_CRYPTO=deepseek/deepseek-chat

# ─── Blockchain RPCs ──────────────────────────────────────────────────────────
BNB_RPC_URL=https://binance.llamarpc.com
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
TON_RPC_URL=https://toncenter.com/api/v2/jsonRPC

# ─── WDK Wallet / Seed ────────────────────────────────────────────────────────
# REQUIRED: BIP-39 mnemonic or hex seed for the agent wallet
WDK_SECRET_SEED=

# ─── WDK Contract Addresses (required) ───────────────────────────────────────
WDK_VAULT_ADDRESS=
WDK_ENGINE_ADDRESS=
WDK_USDT_ADDRESS=
WDK_BREAKER_ADDRESS=
WDK_ZK_ORACLE_ADDRESS=

# ─── WDK Contract Addresses (optional) ───────────────────────────────────────
WDK_AUCTION_ADDRESS=
WDK_SYNDICATE_ADDRESS=
WDK_XAUT_ADDRESS=
WDK_RISK_POLICY_ADDRESS=
WDK_SHARPE_TRACKER_ADDRESS=

# ─── Integrations (optional) ──────────────────────────────────────────────────
# URL the agent will POST reports to (e.g. internal dashboard)
AGENT_REPORT_URL=

# Secret for validating GitHub webhook payloads
GITHUB_WEBHOOK_SECRET=
