# OmniWDK Agent - Backend Environment Variables
# Copy this file to .env and fill in the values

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3001

# ─── OpenRouter (AI / LLM) ────────────────────────────────────────────────────
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL_GENERAL=google/gemini-2.5-flash-lite
OPENROUTER_MODEL_CRYPTO=x-ai/grok-4.1-fast

# ─── Blockchain RPCs ──────────────────────────────────────────────────────────
SEPOLIA_RPC_URL=https://ethereum-sepolia.publicnode.com
# Deprecated: BNB_RPC_URL kept for backward compat
BNB_RPC_URL=https://ethereum-sepolia.publicnode.com

# ─── Wallet / Private Keys ───────────────────────────────────────────────────
# BIP-39 mnemonic or hex seed for the agent wallet
WDK_SECRET_SEED=
PRIVATE_KEY=

# ─── WDK Contract Addresses (Sepolia) ───────────────────────────────────────
# Real Tether USDT on Sepolia: 0xd077a400968890eacc75cdc901f0356c943e4fdb
# Real Tether Gold XAUT on Sepolia: 0x810249ef893d98ac8da4d6eb018e8cf7c16d536c

WDK_VAULT_ADDRESS=0x739D6Bf14C4a37b67Ae000eAAb0AbdABd7C624Af
