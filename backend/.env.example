# OmniAgent FastAPI Casper runtime

PORT=8000
OMNIAGENT_LOG_JSON=true
OMNIAGENT_LOG_STREAM=stdout

# API security
API_SESSION_SECRET=<generate-a-random-64-byte-secret>
# Empty means every browser session is read-only; set a strong secret for operator actions.
API_OPERATOR_TOKEN=
API_SECURITY_ENABLED=true
API_SECURITY_HEADERS_ENABLED=true
API_RATE_LIMIT_ENABLED=true
API_RATE_LIMIT_REQUESTS=600
API_MCP_RATE_LIMIT_REQUESTS=240
API_SESSION_RATE_LIMIT_REQUESTS=180
API_RATE_LIMIT_WINDOW_SEC=60
API_MAX_BODY_BYTES=1048576
API_TRUSTED_HOSTS=localhost,127.0.0.1,testserver,healthcheck.railway.app,*.up.railway.app,*.railway.internal
ALLOWED_FRONTEND_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000,http://127.0.0.1:3000

# Casper Testnet
AGENT_RUNTIME_ADAPTER=fastapi-casper-agent
CASPER_NETWORK=casper-test
CASPER_RPC_URL=https://node.testnet.casper.network/rpc
CASPER_NODE_ADDRESS=
CASPER_RPC_TIMEOUT_SEC=10
CASPER_EXPLORER_URL=https://testnet.cspr.live
CASPER_ACCOUNT_PUBLIC_KEY=
CASPER_SECRET_KEY_PATH=
CASPER_DECISION_CONTRACT_HASH=
CASPER_DECISION_CONTRACT_PACKAGE_HASH=
CASPER_LIVE_SUBMIT_ENABLED=false
CASPER_CLIENT_PATH=casper-client
CASPER_TRANSACTION_COMMAND=put-deploy
CASPER_TRANSACTION_WASM_PATH=
CASPER_TRANSACTION_ENTRY_POINT=record_decision
CASPER_TRANSACTION_CATEGORY=small
CASPER_GAS_PRICE_TOLERANCE=10
CASPER_PRICING_MODE=fixed
CASPER_PAYMENT_AMOUNT_MOTES=2500000000
CASPER_MIN_PAYMENT_AMOUNT_MOTES=2500000000
CASPER_CLI_TIMEOUT_SEC=30
CASPER_AGENT_PUBLIC_ENDPOINT=/.well-known/casper-agent-card.json
CASPER_AGENT_LOOP_ENABLED=false
CASPER_AGENT_LOOP_INTERVAL_SEC=3600
CASPER_AGENT_LOOP_DRY_RUN=true
CASPER_AGENT_LOOP_LIVE_SUBMIT_ENABLED=false
CASPER_AGENT_LOOP_AUTO_READBACK=true
CASPER_AGENT_LOOP_POLL_MAX_RETRIES=10
CASPER_AGENT_LOOP_POLL_INTERVAL_SEC=5
CASPER_CSPR_CLOUD_API_KEY=
CASPER_CSPR_CLOUD_URL=https://api.testnet.cspr.cloud
CASPER_MIN_BALANCE_CSPR=50
CASPER_LIVE_MIN_SUBMIT_INTERVAL_SEC=21600
CASPER_LIVE_MAX_SUBMISSIONS_PER_UTC_DAY=4
CASPER_LIVE_DAILY_BUDGET_MOTES=10000000000
CASPER_LIVE_MAX_RECEIPT_BYTES=512
CASPER_LIVE_REQUIRE_CHAIN_DEDUPE=true
CASPER_DECISION_LEDGER_PATH=dashboard-casper-decision-log
CASPER_X402_EVIDENCE_URL=
CASPER_X402_RECEIPT=
CASPER_X402_FACILITATOR_URL=https://x402-facilitator.cspr.cloud
CASPER_X402_NETWORK=casper:casper-test
CASPER_X402_AMOUNT=1000000
CASPER_X402_PRICE=1000000
CASPER_X402_CURRENCY=WCSPR
CASPER_X402_PAY_TO_ADDRESS=
CASPER_X402_ASSET=3d80df21ba4ee4d66a2a1f60c32570dd5685e4b279f6538162a5fd1314847c1e
CASPER_X402_ASSET_NAME=Wrapped CSPR
CASPER_X402_ASSET_VERSION=1
CASPER_X402_ASSET_DECIMALS=9
CASPER_X402_FEE_PAYER=
CASPER_X402_FACILITATOR_API_KEY=
CASPER_VAULT_CONTRACT_HASH=
CASPER_VAULT_PACKAGE_HASH=
CASPER_VAULT_ENFORCE_ENABLED=false
CASPER_VAULT_ASSET_ID=rwa-demo-collateral-001
CASPER_LLM_TRACE_ENABLED=false
CASPER_LLM_TRACE_PROVIDER=openrouter
CASPER_LLM_TRACE_MODEL=deepseek/deepseek-v4-flash
OPENROUTER_API_KEY=
OPENROUTER_MODEL=deepseek/deepseek-v4-flash
OPENROUTER_FALLBACK_MODEL=deepseek/deepseek-v4-pro
OPENROUTER_SITE_URL=
OPENROUTER_APP_TITLE=OmniAgent Casper Demo
OPENROUTER_TIMEOUT_SEC=10

# MCP tools
MCP_ALLOWED_TOOLS=casper_agent_cockpit_snapshot,casper_get_account,casper_runtime_snapshot,casper_live_preflight,casper_run_autonomous_cycle,casper_live_proof_bundle,casper_get_deploy_status,casper_get_decision_receipt,casper_verify_decision_receipt,casper_record_decision,casper_record_readback
