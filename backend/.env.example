# OmniWDK Agent - Backend Environment Variables
# Copy this file to .env and fill in the values

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3001

# ─── OpenRouter (AI / LLM) ────────────────────────────────────────────────────
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL_GENERAL=google/gemini-2.5-flash-lite
OPENROUTER_MODEL_CRYPTO=x-ai/grok-4.1-fast

# ─── Blockchain RPCs ──────────────────────────────────────────────────────────
SEPOLIA_RPC_URL=https://ethereum-sepolia.publicnode.com
# Deprecated: BNB_RPC_URL kept for backward compat
BNB_RPC_URL=https://ethereum-sepolia.publicnode.com
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
TON_RPC_URL=https://toncenter.com/api/v2/jsonRPC
TON_API_KEY=

# ─── Wallet / Private Keys ───────────────────────────────────────────────────
# BIP-39 mnemonic or hex seed for the agent wallet
WDK_SECRET_SEED=
PRIVATE_KEY=
SOLANA_PRIVATE_KEY=
TON_PRIVATE_KEY=

# ─── WDK Contract Addresses ──────────────────────────────────────────────────
WDK_VAULT_ADDRESS=
WDK_ENGINE_ADDRESS=
WDK_USDT_ADDRESS=
WDK_BREAKER_ADDRESS=
WDK_ZK_ORACLE_ADDRESS=
WDK_AUCTION_ADDRESS=
WDK_SYNDICATE_ADDRESS=
WDK_XAUT_ADDRESS=
WDK_RISK_POLICY_ADDRESS=
WDK_SHARPE_TRACKER_ADDRESS=
WDK_AAVE_ADAPTER_ADDRESS=
WDK_LZ_ADAPTER_ADDRESS=
WDK_POLICY_GUARD_ADDRESS=
WDK_AGENT_NFA_ADDRESS=

# ─── Integrations ────────────────────────────────────────────────────────────
AGENT_REPORT_URL=
AGENT_REPORT_BASE_URL=
GITHUB_WEBHOOK_SECRET=

# ─── OpenClaw Protocol ────────────────────────────────────────────────────────
OPENCLAW_GATEWAY_URL=https://gateway.openclaw.com/api
OPENCLAW_API_KEY=
MAX_OPENCLAW_EXPOSURE_PERCENT=20
MIN_OPENCLAW_APY=8.5

# ─── Velora DEX ──────────────────────────────────────────────────────────────
VELORA_ROUTER_ADDRESS=0x7a250d5630B4cF539739dF2C5dAcb4c659F2488D
VELORA_FACTORY_ADDRESS=0x5C69bEe701ef814a2B6a3EDD4B1652CB9cc5aA6f

# ─── ERC-4337 Smart Accounts ─────────────────────────────────────────────────
ERC4337_FACTORY_ADDRESS=
ERC4337_PAYMASTER_ADDRESS=
ERC4337_ENTRYPOINT_ADDRESS=0x5FF137D4a0ADCA4B1FB0b8274Ea4dE461a706c12

# ─── Deployment ───────────────────────────────────────────────────────────────
DEPLOYMENT_MODE=local
AGENT_CRON_SECRET=
JWT_SECRET=
ALLOW_AGENT_RUN=

# ─── Robot Fleet ──────────────────────────────────────────────────────────────
ROBOT_FLEET_ENABLED=false
ROBOT_FLEET_SIZE=8
ROBOT_FLEET_TASK_INTERVAL_MIN=5000
ROBOT_FLEET_TASK_INTERVAL_MAX=15000
ROBOT_FLEET_EARNINGS_MIN=0.0001
ROBOT_FLEET_EARNINGS_MAX=0.0025
ROBOT_FLEET_AGENT_WALLET=
# Override robot fleet config (JSON array). If not set, uses default robots.
# ROBOT_FLEET_ROBOTS=[{"id":"ROBO-001","type":"Yield Sentry","icon":"[S]"},...]

# ─── Mock Contracts (Testnet) ─────────────────────────────────────────────────
MOCK_AAVE_POOL_ADDRESS=
MOCK_BRIDGE_ADDRESS=
MOCK_ATOKEN_ADDRESS=
MOCK_VUSDT_ADDRESS=

# ─── NAV Shield ──────────────────────────────────────────────────────────────
# Baseline storage path (Railway Volume: /app/cache, local: ./cache)
BASELINE_STORAGE_PATH=
# Maximum NAV drop % per trade (default: 10)
NAV_MAX_DROP_PCT=10

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=info
NODE_ENV=development
