# OmniAgent Backend - Environment Variables Template
# Copy this to .env and fill in required values

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3001

# ─── OpenRouter (AI / LLM) ────────────────────────────────────────────────────
OPENROUTER_API_KEY=
OPENROUTER_MODEL_GENERAL=google/gemini-2.5-flash-lite
OPENROUTER_MODEL_CRYPTO=x-ai/grok-4.1-fast

# ─── Blockchain RPCs ──────────────────────────────────────────────────────────
SEPOLIA_RPC_URL=https://ethereum-sepolia.publicnode.com
ARBITRUM_RPC_URL=https://sepolia-rollup.arbitrum.io/rpc
POLYGON_RPC_URL=https://rpc-amoy.polygon.technology
PLASMA_RPC_URL=https://rpc.chiadochain.net
ETHEREUM_RPC_URL=https://rpc.ankr.com/eth

# ─── Wallet / Private Keys ───────────────────────────────────────────────────
# BIP-39 mnemonic (12-24 words) for agent wallet
WDK_SECRET_SEED=
# Hex private key (without 0x prefix) - optional, derived from WDK_SECRET_SEED
PRIVATE_KEY=

# ─── Deployment ───────────────────────────────────────────────────────────────
DEPLOYMENT_MODE=local
ALLOW_AGENT_RUN=true
JWT_SECRET=

# ─── WDK Core Contracts (Sepolia Testnet) ─────────────────────────────────
# Real Tether USDT: https://sepolia.etherscan.io/token/0xd077a400968890eacc75cdc901f0356c943e4fdb
WDK_USDT_ADDRESS=0xd077a400968890eacc75cdc901f0356c943e4fdb
WDK_XAUT_ADDRESS=0x810249ef893d98ac8da4d6eb018e8cf7c16d536c
WDK_VAULT_ADDRESS=0x739D6Bf14C4a37b67Ae000eAAb0AbdABd7C624Af
WDK_ENGINE_ADDRESS=0x4A3e42E49b69ef0fD569bdc50354EaB444f36476

# Oracles (Chainlink)
WDK_USDT_ORACLE_ADDRESS=0x694AA1769357215DE4FAC081bf1f309aDC325306
WDK_XAUT_ORACLE_ADDRESS=0x1b44F3514812d835EB1BDB0acB33d3fA3351Ee43

# Risk & Governance
WDK_POLICY_GUARD_ADDRESS=0xE4fFcace565701C231FAF0222e3963e3c5a50690
WDK_AGENT_NFA_ADDRESS=0xf66e0865cCd84652808a261f97609862f4BA8c4c
WDK_BREAKER_ADDRESS=0xf5B7bF143045B0e59E2D854726424A8C77CE2250
