WDK_ZK_ORACLE_ADDRESS=0x01aCCB9ceADFe3dE6070e9859795A46e3B435CD1

# ─── ERC-4337 Smart Accounts (EntryPoint v0.7) ────────────────────────────────
SIMPLE_ACCOUNT_FACTORY_ADDRESS=0x738428DD7930EBB2f61763a18C805782A1A6586b
ERC4337_ENTRYPOINT_ADDRESS=0x0000000071727De22E5E9d8BAf0edAc6f37da032
# Bundler & Paymaster (Candide)
BUNDLER_URL=https://api.candide.dev/public/v3/11155111
PAYMASTER_URL=https://api.candide.dev/public/v3/11155111
PAYMASTER_ADDRESS=0x8b1f6cb5d062aa2ce8d581942bbb960420d875ba

# ─── x402 Protocol ─────────────────────────────────────────────────────────────
X402_FACILITATOR_URL=https://x402.semanticpay.io/
X402_NETWORK=eip155:9745

# ─── OpenClaw Protocol ───────────────────────────────────────────────────────
OPENCLAW_GATEWAY_URL=https://gateway.openclaw.com/api
OPENCLAW_API_KEY=
MAX_OPENCLAW_EXPOSURE_PERCENT=20
MIN_OPENCLAW_APY=8.5

# ─── Robot Fleet ──────────────────────────────────────────────────────────────
ROBOT_FLEET_ENABLED=false
ROBOT_FLEET_SIZE=6
ROBOT_FLEET_TASK_INTERVAL_MIN=3600000
ROBOT_FLEET_TASK_INTERVAL_MAX=7200000
ROBOT_FLEET_EARNINGS_MIN=0.1
ROBOT_FLEET_EARNINGS_MAX=0.5
ROBOT_FLEET_MIN_TRANSFER_THRESHOLD=2.0
ROBOT_FLEET_USE_WDK_AGENTS=true
ROBOT_FLEET_X402_ENABLED=true

# ─── HashKey Chain (Testnet) ────────────────────────────────────────────────
HASHKEY_CHAIN_ENABLED=false
HASHKEY_RPC_URL=https://testnet.hsk.xyz
HASHKEY_CHAIN_ID=133
HASHKEY_EXPLORER_URL=https://testnet-explorer.hsk.xyz
HASHKEY_VAULT_ADDRESS=0x605b6b8C83d8b0EA8867BEda4099DE4F042F7318
HASHKEY_USDT_ADDRESS=0xA3eb6Cb28659ec53388FE5Ff3E64920e3C274038
HASHKEY_KYC_SBT_ADDRESS=0x1525E262Cb5bDFC7b51802c36a1141bA94405F76

# ZK Identity Gate (Noir circuit — age, jurisdiction, KYC, agent auth)
HASHKEY_ZK_GATE_ADDRESS=0x82f3c7967Fe2A0ae8C9C3caCA79b8c5C1805843E
HASHKEY_ZK_VERIFIER_ADDRESS=0xBf90d38B9128FB70C91F0D1CB9908c5F5eE28276

# AI Agent On-Chain
HASHKEY_AGENT_NFA_ADDRESS=0xdFf5A296102818507313639E646C15cC53c5153A
HASHKEY_POLICY_GUARD_ADDRESS=0x1E997a52FEd011C74d5a8579a74DEf1BaC035fcD

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=info
NODE_ENV=development
