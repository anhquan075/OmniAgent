{
  "name": "omni-agent",
  "version": "1.0.0",
  "description": "Autonomous, non-custodial yield routing stack on WDK multi-chain (Sepolia, Polygon, Arbitrum, Plasma, Ethereum).",
  "type": "commonjs",
  "main": "index.js",
  "directories": {
    "doc": "docs",
    "test": "test"
  },
  "scripts": {
    "compile": "hardhat compile",
    "test": "hardhat test",
    "test:hono": "vitest run src/api/routes/stats.test.ts",
    "test:smoke": "vitest run test/smoke/",
    "test:smoke:watch": "vitest test test/smoke/",
    "node": "hardhat node",
    "dev": "tsx watch src/index.ts",
    "build": "tsc && tsc-alias",
    "build:cloudflare": "npm run build",
    "start": "node dist/index.js",
    "deploy:full": "DEPLOY_CMD=full npx hardhat run scripts/deploy.ts --network sepolia",
    "deploy:zk-oracle": "DEPLOY_CMD=zk-oracle npx hardhat run scripts/deploy.ts --network sepolia",
    "deploy:seed": "DEPLOY_CMD=seed npx hardhat run scripts/deploy.ts --network sepolia",
    "deploy:init": "DEPLOY_CMD=init npx hardhat run scripts/deploy.ts --network sepolia",
    "deploy:whitelist": "DEPLOY_CMD=whitelist npx hardhat run scripts/deploy.ts --network sepolia",
    "inspect:contracts": "INSPECT_CMD=check-contracts npx hardhat run scripts/inspect.ts --network sepolia",
    "inspect:vault": "INSPECT_CMD=check-vault npx hardhat run scripts/inspect.ts --network sepolia",
    "inspect:smoke": "INSPECT_CMD=smoke-test npx hardhat run scripts/inspect.ts --network sepolia",
    "robot:start": "tsx src/scripts/robot-simulator.ts",
    "robot:dev": "tsx watch src/scripts/robot-simulator.ts",
    "frontend:dev": "pnpm --dir ../frontend run dev",
    "frontend:build": "pnpm --dir ../frontend run build",
    "deploy:pages": "wrangler pages deploy . --project-name omni-agent"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241127.0",
    "@nomicfoundation/hardhat-toolbox": "^6.1.2",
    "@types/axios": "^0.14.4",
    "@types/cors": "^2.8.19",
    "@types/node": "^25.5.0",
    "@types/pino": "^7.0.5",
    "hardhat": "^2.28.6",
    "ts-node": "^10.9.2",
    "tsc-alias": "^1.8.16",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0",
    "wrangler": "^4.75.0"
  },
  "dependencies": {
    "@account-abstraction/contracts": "^0.8.0",
    "@account-abstraction/sdk": "^0.6.0",
    "@ai-sdk/openai": "^3.0.41",
    "@hono/node-server": "^1.19.11",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@openrouter/ai-sdk-provider": "^2.3.3",
    "@openzeppelin/contracts": "^5.4.0",
    "@tetherto/wdk": "^1.0.0-beta.6",
    "@tetherto/wdk-mcp-toolkit": "github:tetherto/wdk-mcp-toolkit",
    "@tetherto/wdk-pricing-bitfinex-http": "1.0.0-beta.2",
    "@tetherto/wdk-protocol-bridge-usdt0-evm": "^1.0.0-beta.3",
    "@tetherto/wdk-protocol-lending-aave-evm": "^1.0.0-beta.3",
    "@tetherto/wdk-protocol-swap-velora-evm": "^1.0.0-beta.1",
    "@tetherto/wdk-wallet-evm": "^1.0.0-beta.8",
    "@tetherto/wdk-wallet-evm-erc-4337": "1.0.0-beta.5",
    "@x402/core": "^2.7.0",
    "@x402/evm": "^2.7.0",
    "@x402/fetch": "^2.7.0",
    "ai": "^6.0.116",
    "axios": "^1.13.6",
    "bs58": "^6.0.0",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "ethers": "^6.16.0",
    "express": "^5.2.1",
    "hono": "^4.12.7",
    "hono-pino": "^0.10.3",
    "jose": "^5.9.6",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "zod": "^4.3.6"
  },
  "optionalDependencies": {
    "ioredis": "^5.10.1"
  }
}
