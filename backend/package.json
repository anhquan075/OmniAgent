{
  "name": "omni-agent",
  "version": "1.0.0",
  "description": "Autonomous, non-custodial yield routing stack on BNB Chain.",
  "type": "commonjs",
  "main": "index.js",
  "directories": {
    "doc": "docs",
    "test": "test"
  },
  "scripts": {
    "compile": "hardhat compile",
    "test": "hardhat test",
    "test:local-execute-cycle": "hardhat run scripts/LocalExecuteCycleFlow.js --network hardhat",
    "test:hono": "vitest run src/api/routes/stats.test.ts",
    "test:smoke:testnet": "hardhat run scripts/FullFlownetSmokeTest.js --network bnbTestnet",
    "deploy:full": "hardhat run scripts/DeployStackWithSeed.ts --network localhost",
    "smoke:agent": "hardhat run scripts/AgentSmokeTest.ts --network localhost",
    "node": "hardhat node",
    "dev": "tsx watch src/index.ts",
    "build": "tsc && tsc-alias",
    "build:cloudflare": "npm run build",
    "start": "node dist/index.js",
    "robot:start": "tsx src/scripts/robot-simulator.ts",
    "robot:dev": "tsx watch src/scripts/robot-simulator.ts",
    "frontend:dev": "pnpm --dir ../frontend run dev",
    "frontend:build": "pnpm --dir ../frontend run build",
    "deploy:pages": "wrangler pages deploy . --project-name omni-agent"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241127.0",
    "@nomicfoundation/hardhat-toolbox": "^6.1.2",
    "@types/axios": "^0.14.4",
    "@types/cors": "^2.8.19",
    "@types/node": "^25.5.0",
    "@types/pino": "^7.0.5",
    "hardhat": "^2.28.6",
    "ts-node": "^10.9.2",
    "tsc-alias": "^1.8.16",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0",
    "wrangler": "^3.97.0"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.41",
    "@hono/node-server": "^1.19.11",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@openzeppelin/contracts": "^5.4.0",
    "@solana/web3.js": "^1.98.4",
    "@tetherto/wdk": "^1.0.0-beta.6",
    "@tetherto/wdk-mcp-toolkit": "github:tetherto/wdk-mcp-toolkit",
    "@tetherto/wdk-protocol-swap-velora-evm": "^1.0.0-beta.1",
    "@tetherto/wdk-protocol-lending-aave-evm": "^1.0.0-beta.3",
    "@tetherto/wdk-protocol-bridge-usdt0-evm": "^1.0.0-beta.3",
    "@tetherto/wdk-wallet-evm": "^1.0.0-beta.8",
    "@tetherto/wdk-wallet-solana": "^1.0.0-beta.5",
    "@tetherto/wdk-wallet-ton": "^1.0.0-beta.7",
    "@ton/ton": "^16.2.2",
    "ai": "^6.0.116",
    "axios": "^1.13.6",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "ethers": "^6.16.0",
    "express": "^5.2.1",
    "hono": "^4.12.7",
    "hono-pino": "^0.10.3",
    "jose": "^5.9.6",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "zod": "^4.3.6"
  },
  "pnpm": {
    "overrides": {
      "zod": "^4.3.6"
    }
  }
}
