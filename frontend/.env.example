# WDKVault V2 Frontend Environment Variables
# Copy this to .env or .env.local

# ─── Network ──────────────────────────────────────────────────────────────────
VITE_DEFAULT_NETWORK=testnet

# ─── RPC URLs ─────────────────────────────────────────────────────────────────
VITE_SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/YOUR_INFURA_KEY
VITE_ETHEREUM_RPC_URL=https://mainnet.infura.io/v3/YOUR_INFURA_KEY

# ─── Sepolia Testnet Contracts ────────────────────────────────────────────────
VITE_SEPOLIA_VAULT_ADDRESS=
VITE_SEPOLIA_ENGINE_ADDRESS=
VITE_SEPOLIA_TOKEN_ADDRESS=
VITE_SEPOLIA_VUSDT_ADDRESS=
VITE_SEPOLIA_CIRCUIT_BREAKER_ADDRESS=
VITE_SEPOLIA_SHARPE_TRACKER_ADDRESS=
VITE_SEPOLIA_PEG_ARB_EXECUTOR_ADDRESS=
VITE_SEPOLIA_POLICY_ADDRESS=
VITE_SEPOLIA_WDK_ADAPTER_ADDRESS=
VITE_SEPOLIA_SECONDARY_ADAPTER_ADDRESS=
VITE_SEPOLIA_EXECUTION_AUCTION_ADDRESS=

# ─── Ethereum Mainnet Contracts ──────────────────────────────────────────────
VITE_ETHEREUM_VAULT_ADDRESS=
VITE_ETHEREUM_ENGINE_ADDRESS=
VITE_ETHEREUM_TOKEN_ADDRESS=
VITE_ETHEREUM_VUSDT_ADDRESS=
VITE_ETHEREUM_CIRCUIT_BREAKER_ADDRESS=
VITE_ETHEREUM_SHARPE_TRACKER_ADDRESS=
VITE_ETHEREUM_PEG_ARB_EXECUTOR_ADDRESS=
VITE_ETHEREUM_POLICY_ADDRESS=
VITE_ETHEREUM_WDK_ADAPTER_ADDRESS=
VITE_ETHEREUM_SECONDARY_ADAPTER_ADDRESS=
VITE_ETHEREUM_EXECUTION_AUCTION_ADDRESS=
VITE_ETHEREUM_LP_ADAPTER_ADDRESS=

# ─── Block Explorers ──────────────────────────────────────────────────────────
VITE_SEPOLIA_BLOCK_EXPLORER=https://sepolia.etherscan.com
VITE_ETHEREUM_BLOCK_EXPLORER=https://etherscan.io
VITE_WDK_BLOCK_EXPLORER=https://scan.wdk.io

# ─── API ─────────────────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:3001

# ─── WalletConnect ───────────────────────────────────────────────────────────
VITE_WALLETCONNECT_PROJECT_ID=
