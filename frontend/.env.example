# OmniAgent Frontend - Environment Variables Template
# Copy this to .env and fill in values

# ─── Network ──────────────────────────────────────────────────────────────────
VITE_DEFAULT_NETWORK=bsc

# ─── RPC URLs ─────────────────────────────────────────────────────────────────
VITE_BNB_RPC_URL=https://bsc-dataseed.bnbchain.org

# ─── API ─────────────────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:8000

# ─── WalletConnect ───────────────────────────────────────────────────────────
VITE_WALLETCONNECT_PROJECT_ID=

# ─── Block Explorers ──────────────────────────────────────────────────────────
VITE_BNB_BLOCK_EXPLORER=https://bscscan.com

# ─── BNB Smart Chain Mainnet ────────────────────────────────────────────────
VITE_BNB_USDT_ADDRESS=0x55d398326f99059fF775485246999027B3197955
VITE_BNB_COMPETITION_CONTRACT_ADDRESS=0x212c61b9b72c95d95bf29cf032f5e5635629aed5
