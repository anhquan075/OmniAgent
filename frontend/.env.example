# WDKVault V2 Frontend Environment Variables
# Copy this to .env or .env.local

# Default network mode (testnet, creditcoin_testnet, polkadot_hub)
VITE_DEFAULT_NETWORK=testnet

# BNB Testnet RPC
VITE_BSC_TESTNET_RPC_URL=https://bsc-testnet-rpc.publicnode.com

# Contracts - BNB Testnet
VITE_TESTNET_VAULT_ADDRESS=0xA7207caCEA25b8a9BFf289C8aCCcD257C862314D
VITE_TESTNET_ENGINE_ADDRESS=0x6518CFAf53C39D6127723D67402e63E636Dd1c3E
VITE_TESTNET_TOKEN_ADDRESS=0x74bda872E528c58D66d5DBd9Bb9072b06d99f510
VITE_TESTNET_CIRCUIT_BREAKER_ADDRESS=0xfB5D6f83b1a5c42dFCd3fFAF76d0eF0d5ae5cB66
VITE_TESTNET_SHARPE_TRACKER_ADDRESS=0xe4eB72e5d29AA868948F2a691255BAAFf4A8b479
VITE_TESTNET_PEG_ARB_EXECUTOR_ADDRESS=0xeE5Fd164378Dca028586ef4C72e633A7b248dC1c
VITE_TESTNET_POLICY_ADDRESS=0x55D9BCB9F13Ca2d5aD3345E60234E48e6A719133
VITE_TESTNET_WDK_ADAPTER_ADDRESS=0x096148CE528701614dF518B217A430A88635d561
VITE_TESTNET_SECONDARY_ADAPTER_ADDRESS=0x30d4F9f3e98BadD935872b03F64Bdb4F7AaE8628
