# OmniAgent Frontend - Environment Variables Template
# Copy this to .env and fill in values

# ─── Network ──────────────────────────────────────────────────────────────────
VITE_DEFAULT_NETWORK=testnet

# ─── Dev Mode ─────────────────────────────────────────────────────────────────
# Force HashKey features visible (for testing on non-HashKey networks)
VITE_DEV_MODE_HASHKEY=false

# ─── RPC URLs ─────────────────────────────────────────────────────────────────
VITE_SEPOLIA_RPC_URL=https://ethereum-sepolia.publicnode.com
VITE_ETHEREUM_RPC_URL=https://ethereum.publicnode.com

# ─── API ─────────────────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:3001

# ─── WalletConnect ───────────────────────────────────────────────────────────
VITE_WALLETCONNECT_PROJECT_ID=

