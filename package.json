{
  "name": "tether-proof-wdk",
  "version": "1.0.0",
  "description": "Autonomous, non-custodial yield routing stack on BNB Chain.",
  "main": "index.js",
  "directories": {
    "doc": "docs",
    "test": "test"
  },
  "scripts": {
    "start:agent": "cd agent && node loop.js",
    "agent:mcp": "cd agent && node server.js",
    "compile": "hardhat compile",
    "test": "hardhat test",
    "test:local-execute-cycle": "hardhat run scripts/LocalExecuteCycleFlow.js --network hardhat",
    "test:hono": "vitest run src/api/routes/stats.test.ts",
    "test:smoke:mainnet-fork": "hardhat run scripts/MainnetForkSmokeTest.js",
    "test:smoke:testnet": "hardhat run scripts/FullFlowTestnetSmoke.js --network bnbTestnet",
    "deploy:aster:adapter": "hardhat run scripts/DeployAsterAdapter.js --network bnb",
    "deploy:aster:stack": "hardhat run scripts/DeployAsterStack.js --network bnb",
    "derive:aster:envs": "node scripts/DeriveAsterEnvs.js",
    "node": "hardhat node",
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "frontend:dev": "npm --prefix frontend run dev",
    "frontend:build": "npm --prefix frontend run build"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^6.1.2",
    "@polkadot/api": "^16.5.4",
    "@polkadot/types": "^16.5.4",
    "@polkadot/util": "^14.0.1",
    "@types/cors": "^2.8.19",
    "@types/node": "^25.5.0",
    "hardhat": "^2.28.6",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.41",
    "@hono/node-server": "^1.19.11",
    "@langchain/anthropic": "^1.3.23",
    "@langchain/core": "^1.1.32",
    "@langchain/langgraph": "^1.2.2",
    "@langchain/openai": "^1.2.13",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@openzeppelin/contracts": "^5.4.0",
    "@tetherto/wdk": "^1.0.0-beta.6",
    "@tetherto/wdk-wallet-evm": "^1.0.0-beta.8",
    "@tetherto/wdk-wallet-solana": "^1.0.0-beta.5",
    "@tetherto/wdk-wallet-ton": "^1.0.0-beta.7",
    "ai": "^6.0.116",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "ethers": "^6.16.0",
    "express": "^5.2.1",
    "hono": "^4.12.7",
    "zod": "^4.3.6"
  }
}
